{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "references": [{ "path": "../content" }],
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
